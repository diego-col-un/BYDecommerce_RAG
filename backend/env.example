# =============================================
# CONFIGURACIÓN DEL PROYECTO RAG - VEHÍCULOS
# =============================================

# Tu API Key de OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=sk-or-v1-XXXXXXXXXXXXXXXXXXXXXXXX

# Modelo LLM a usar via OpenRouter
LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Configuración del servidor
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True

# Ruta al catálogo
CATALOG_PATH=data/catalogo_vehiculos.csv

# Ruta para guardar el índice FAISS
INDEX_PATH=embeddings/faiss_index
